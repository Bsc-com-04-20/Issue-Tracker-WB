# Copy to .env and adjust. See env.validation.ts for all keys.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=issue_tracking_system
DB_SYNC=true
# Run TypeORM migrations on startup (required once after role model changes).
MIGRATIONS_RUN=true

JWT_SECRET=dev-secret-change-me

# --- Email ---
# Development: Ethereal fake SMTP (logs a browser preview URL after each send).
SMTP_USE_ETHEREAL=true
NOTIFY_EMAIL=you@example.com
# Also receives supervisor-escalation emails in addition to every active user with role supervisor.
#
# Production: turn off Ethereal and set real SMTP (Gmail needs an App Password).
# SMTP_USE_ETHEREAL=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraccount@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=Issue Tracker <youraccount@gmail.com>
# NOTIFY_EMAIL=optional-fallback-if-no-reporter-email

# --- SMS (placeholder adapter, ready for Airtel/TNM integration) ---
SMS_ENABLED=false
SMS_PROVIDER=noop
#
# Set provider to airtel or tnm when gateway integration is implemented.
# SMS_PROVIDER=airtel
# SMS_AIRTEL_BASE_URL=
# SMS_AIRTEL_API_KEY=
# SMS_AIRTEL_SENDER_ID=
#
# SMS_PROVIDER=tnm
# SMS_TNM_BASE_URL=
# SMS_TNM_API_KEY=
# SMS_TNM_SENDER_ID=

# --- Operational coordination (optional) ---
# Cap simultaneous assigned / in-progress issues per technician (0 = disable cap).
MAX_ACTIVE_ASSIGNMENTS_PER_TECHNICIAN=12
#
# When true, supervisors and department officers cannot close until the customer confirms
# resolution on the public track page (administrators may still close).
# REQUIRE_CUSTOMER_RESOLUTION_ACK_BEFORE_CLOSE=false

# --- Meter registry (mock / CIS integration point) ---
# Optional merge file: JSON object keyed by meter number (same shape as registry seed).
# METER_REGISTRY_MERGE_PATH=config/meter-registry.merge.example.json
# Zomba mock meters: waterboard-issue-system/seed/meter-registry.merge.json
# METER_VERIFICATION_DEMO_OTP=000000
# METER_VERIFICATION_EXPOSE_OTP_IN_RESPONSE=true
# METER_VERIFICATION_TTL_MS=900000
